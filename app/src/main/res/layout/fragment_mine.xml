<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 个人中心入口 -->
    <LinearLayout
        android:id="@+id/layout_personal_center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center"
        android:padding="@dimen/spacing_xxl"
        android:orientation="vertical">

        <ImageView
            android:layout_width="@dimen/avatar_size_xl"
            android:layout_height="@dimen/avatar_size_xl"
            android:src="@android:mipmap/ic_launcher" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="点击进入个人中心"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_md" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:text="@string/nav_mine"
        android:textColor="@color/text_hint"
        android:textSize="@dimen/text_size_lg"
        android:layout_gravity="center"/>

</LinearLayout>
