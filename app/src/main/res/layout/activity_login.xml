<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl">

    <!-- Logo -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:src="@android:mipmap/ic_launcher" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/colorPrimary"
        android:textSize="@dimen/text_size_xxl"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_xxl"/>

    <!-- 手机号 -->
    <EditText
        android:id="@+id/et_phone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:background="@drawable/bg_edit_text"
        android:hint="@string/phone_hint"
        android:inputType="phone"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_md" />

    <!-- 验证码 -->
    <LinearLayout
        android:id="@+id/layout_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_code"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_md"
            android:layout_weight="1"
            android:background="@drawable/bg_edit_text"
            android:hint="@string/code_hint"
            android:inputType="number"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_md" />

        <Button
            android:id="@+id/btn_get_code"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_md"
            android:layout_marginStart="@dimen/spacing_md"
            android:backgroundTint="@color/colorPrimary"
            android:text="@string/get_code"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_sm" />
    </LinearLayout>

    <!-- 密码 -->
    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_md"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:background="@drawable/bg_edit_text"
        android:hint="@string/password_hint"
        android:inputType="textPassword"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_md" />

    <!-- 登录按钮 -->
    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_lg"
        android:backgroundTint="@color/colorPrimary"
        android:text="@string/login"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_lg"
        android:textStyle="bold" />

    <!-- 注册和密码登录 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_sm" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xl"
            android:id="@+id/tv_password_login"
            android:text="@string/password_login"
            android:textColor="@color/colorPrimary"
            android:textSize="@dimen/text_size_sm" />
    </LinearLayout>

</LinearLayout>
