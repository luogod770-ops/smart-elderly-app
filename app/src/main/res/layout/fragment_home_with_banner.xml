<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner轮播 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/banner_pager"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="@dimen/spacing_sm" />

        <!-- SOS按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_sos"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:backgroundTint="@color/red"
                android:text="@string/sos"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_xxxl"
                android:textStyle="bold"
                app:cornerRadius="75dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="点击发送紧急求助"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_size_sm" />

        </LinearLayout>

        <!-- 功能菜单 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:background="@drawable/bg_edit_text"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="常用功能"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_md"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/menu_house"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_myplaces" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/my_house"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_xs" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menu_community"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_compass" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/community"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_xs" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menu_device"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_info_details" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/device"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_xs" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menu_member"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_view" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/member"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_xs" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 系统公告 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_md"
            android:background="@drawable/bg_edit_text"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="公告"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_size_sm"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="欢迎使用智慧养老社区APP"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_sm" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
